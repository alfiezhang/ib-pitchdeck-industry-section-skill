{
  "_description": "Page-level PPT layout budgets used by storyboard prompts and validators. Budgets are intentionally conservative so generated copy fits the fixed template without post-hoc shrinking.",
  "global": {
    "main_message": {
      "forbid_terminal_punctuation": true,
      "terminal_punctuation": "。．.，,、；;：:！!？?",
      "max_lines": 2,
      "target_lines": 1
    },
    "body_copy": {
      "no_inline_sources": true,
      "max_bullet_units_default": 88,
      "max_bullet_units_table": 34,
      "max_bullet_units_compact": 72,
      "max_newlines_per_field": 1,
      "forbid_paragraphs": true
    },
    "visual": {
      "renderable_chart_types": ["bar", "column", "clustered_bar", "clustered_column", "stacked_bar", "stacked_column", "line", "line_chart", "metric_cards", "matrix", "none"],
      "forbid_instructional_chart_titles": true
    },
    "table": {
      "preferred_separator": "｜",
      "min_body_font_pt": 10.0,
      "min_header_font_pt": 10.0,
      "max_cell_units": 22
    }
  },
  "slide_budgets": {
    "1:summary_page": {
      "body_fields_max_units": {
        "bullet_1": 74,
        "bullet_2": 74,
        "bullet_3": 74
      },
      "slide_1_visual": {
        "preferred_chart_types": ["metric_cards", "bar", "line"],
        "min_metric_cards": 3,
        "max_metric_cards": 3,
        "forbid_none_unless_no_verified_metrics": true
      }
    },
    "8:summary_page": {
      "body_fields_max_units": {
        "left_panel": 78,
        "right_top": 78,
        "right_mid": 78,
        "right_bottom": 78
      },
      "slide_8_body": {
        "must_be_investment_thesis": true,
        "avoid_memo_summary": true
      }
    }
  },
