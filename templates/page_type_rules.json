{
  "workflow_scope": "fixed_8_slide_standard_only",
  "input_policy": {
    "presentation_hint_is_soft_input_only": true,
    "visual_candidate_is_soft_input_only": true,
    "upstream_input_cannot_choose_final_page_type": true
  },
  "slides": [
    {
      "slide_no": 1,
      "slide_key": "industry_overview",
      "selection_mode": "fixed",
      "page_types": ["summary_page"],
      "default_dominant_element": "text"
    },
    {
      "slide_no": 2,
      "slide_key": "market_size_segmentation",
      "selection_mode": "controlled_choice",
      "page_types": ["chart_page", "chart_plus_mini_table_page"],
      "default_dominant_element": "chart",
      "selection_priority": [
        "prefer_chart_plus_mini_table_when_segment_split_needs_side-by-side quantitative context",
        "prefer_chart_page_when_one visual can carry the page clearly"
      ]
    },
    {
      "slide_no": 3,
      "slide_key": "key_industry_drivers",
      "selection_mode": "controlled_choice",
      "page_types": ["driver_card_page", "driver_card_5_page", "driver_card_6_page"],
      "default_dominant_element": "text",
      "selection_priority": [
        "prefer_driver_card_page when the slide has exactly 4 MECE drivers or when the fifth/sixth point is weak",
        "prefer_driver_card_5_page when the research supports 5 distinct drivers with no forced filler",
        "prefer_driver_card_6_page when the research supports 6 distinct drivers and each can be stated concisely"
      ]
    },
    {
      "slide_no": 4,
      "slide_key": "value_chain_profit_pool",
      "selection_mode": "fixed",
      "page_types": ["value_chain_page"],
      "default_dominant_element": "diagram"
    },
    {
      "slide_no": 5,
      "slide_key": "key_barriers_value_drivers",
      "selection_mode": "fixed",
      "page_types": ["moat_page"],
      "default_dominant_element": "text"
    },
    {
      "slide_no": 6,
      "slide_key": "competitive_landscape",
      "selection_mode": "controlled_choice",
      "page_types": ["compare_table_page", "matrix_page"],
      "default_dominant_element": "table",
      "selection_priority": [
        "prefer_compare_table_when named peer comparison is the clearest story",
        "prefer_matrix_when positioning against two dimensions is the clearest story"
      ]
    },
    {
      "slide_no": 7,
      "slide_key": "industry_trends_future_evolution",
      "selection_mode": "controlled_choice",
      "page_types": ["trend_page", "timeline_page", "trend_4_card_page", "trend_5_card_page", "trend_6_card_page"],
      "default_dominant_element": "text",
      "selection_priority": [
        "prefer_trend_page when the slide has exactly 3 parallel trends or when additional trend candidates are weak",
        "prefer_trend_4_card_page when the research supports 4 distinct parallel trends",
        "prefer_trend_5_card_page when the research supports 5 distinct parallel trends that can fit as concise cards",
        "prefer_trend_6_card_page when the research supports 6 distinct parallel trends and each card can remain compact",
        "prefer_timeline_page when sequence and timing are central to the story"
      ]
    },
    {
      "slide_no": 8,
      "slide_key": "key_takeaways_for_target",
      "selection_mode": "fixed",
      "page_types": ["summary_page"],
      "default_dominant_element": "text"
    }
  ]
}
